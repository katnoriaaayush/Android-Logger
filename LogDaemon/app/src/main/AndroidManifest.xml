<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        PRIVILEGED SYSTEM APP REQUIREMENTS:

        1. APK MUST be signed with the device platform key (see app/build.gradle.kts).
        2. APK MUST be placed in /system/priv-app/LogDaemon/ on the device.
        3. A privapp-permissions XML must whitelist the protected permissions
           (see README — install at /system/etc/permissions/).

        DO NOT use android:sharedUserId="android.uid.system".
        Since Android 10, sharedUserId is immutable post-install, and since
        Android 13, no app declaring it can be installed after the firmware
        image is built. You will see:
            INSTALL_FAILED_SHARED_USER_INCOMPATIBLE
            "bad user id, non-preload app"

        Platform-signed + /system/priv-app/ + privapp-permissions whitelist
        gives us everything we need for this daemon WITHOUT sharedUserId.
    -->

    <uses-permission android:name="android.permission.READ_LOGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WRITE_MEDIA_STORAGE"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <application
        android:name=".LogDaemonApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:directBootAware="true"
        tools:ignore="AllowBackup">

        <!-- Boot receiver: starts the service when the device boots -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:singleUser="true"
            android:directBootAware="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- USB mount receiver: updates hint file and relaunches helper if needed -->
        <receiver
            android:name=".usb.UsbStateReceiver"
            android:enabled="true"
            android:exported="true"
            android:singleUser="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_MOUNTED" />
                <data android:scheme="file" />
            </intent-filter>
        </receiver>

        <!--
            One-shot launcher service: checks if helper is alive, launches it if not,
            then calls stopSelf(). The native helper outlives this service.
            No <intent-filter> for LAUNCHER => no launcher icon.
        -->
        <service
            android:name=".LogDaemonService"
            android:enabled="true"
            android:exported="false"
            android:singleUser="true"
            android:stopWithTask="false"
            android:directBootAware="true" />

    </application>

</manifest>
